# Local .terraform directories
.terraform/

# Terraform state files
terraform.tfstate
terraform.tfstate.backup
.terraform.lock.hcl
.terraform.tfstate.lock.info
terraform.tfstate
errored.tfstate

# Crash log files
crash.log
crash.*.log

# Exclude lock file if you prefer not to track provider versions
# (але у більшості випадків краще залишати його у репозиторії)
#.terraform.lock.hcl

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files (локальні налаштування, які не мають бути у репо)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

tfplan

# -------------
.env
.env.*
/docker/*
/docker
# ------------

# Kubernetes configuration files
.kube/
.kubeconfig
kubeconfig
*.kubeconfig

# Helm charts build artifacts
charts/*.tgz

# Kubernetes manifests overrides
*.override.yaml
*.override.yml

# Sensitive Kubernetes secrets
secrets.yaml
secrets.yml
*.secret.yaml
*.secret.yml

# Temporary kubectl output files
kubectl-output.log


